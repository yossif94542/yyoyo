<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Zokra">
    <meta name="theme-color" content="#fff0f5">
    <title>Zokra Vault</title>

    <!-- Blank Favicon to prevent browser loop requests -->
    <link rel="icon" href="data:;base64,iVBORw0KGgo=">

    <!-- Premium Fonts per Request (Serif, Script, Sans, Pixel) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Playfair+Display:ital,wght@0,700;1,700&family=Nunito:wght@400;600;800;900&family=Poppins:wght@400;500;600&family=Cairo:wght@700;900&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <!-- Firebase v8 Compat SDKs (Consistent & Reliable) -->
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>

    <style>
        /* Global Core Variables */
        :root {
            --bg: #FCE4EC;
            --cd: #FAF3E0;
            --rad: 45px;
            --blur: 10px;
        }

        body,
        html {
            margin: 0;
            padding: 0;
            background-color: var(--bg);
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
            font-family: 'Nunito', 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif;
            height: 100dvh;
            overflow-x: hidden;
            touch-action: manipulation;
            user-select: none;
            -webkit-user-select: none;
            -webkit-tap-highlight-color: transparent;
            -webkit-overflow-scrolling: touch;
            transform: translate3d(0, 0, 0);
        }

        body.drawer-open {
            overflow: hidden !important;
            touch-action: none;
        }

        input,
        textarea,
        [contenteditable="true"] {
            user-select: text !important;
            -webkit-user-select: text !important;
        }

        /* ECONOMY FONTS CSS */
        .locked-font {
            filter: blur(4px) opacity(0.8) grayscale(1) !important;
            font-family: 'Arial', sans-serif !important;
            user-select: none !important;
            pointer-events: none !important;
            transition: all 0.4s ease;
        }

        /* GLOBAL FULL SCREEN OVERLAYS */
        .locked-full-overlay {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            height: 100dvh !important;
            background-color: #fdf5f5 !important;
            z-index: 99999 !important;
            overflow-y: auto !important;
            display: none;
            /* Default hidden */
            flex-direction: column;
        }

        #master-hq-admin.locked-full-overlay {
            background-color: #0D0B10 !important;
        }

        .locked-full-overlay.open,
        .locked-full-overlay.active {
            display: flex !important;
        }

        .scard.moving,
        .f-drag.actively-dragging {
            will-change: transform;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }

        /* Ensure all buttons and interactive elements have a minimum touch target size */
        button,
        input[type="button"],
        input[type="submit"],
        input[type="file"],
        select,
        .k-btn,
        .k-btn-del,
        .mode-tab,
        .font-btn,
        .mood-emoji,
        .touch-target {
            min-height: 44px;
            min-width: 44px;
            touch-action: manipulation;
        }

        /* Prevents horizontal overflow across the board */
        * {
            box-sizing: border-box;
            max-width: 100vw;
        }

        body.is-guest>*:not(#login-screen):not(script):not(style):not(#m-login-modal) {
            display: none !important;
        }

        /* Enforce Apple Emoji cross-platform precedence */
        @font-face {
            font-family: "Apple Color Emoji";
            src: local("Apple Color Emoji");
        }

        /* Typography System */
        .f-ser {
            font-family: 'Playfair Display', serif;
        }

        .f-pop {
            font-family: 'Poppins', sans-serif;
        }

        .pink-bold {
            color: #FF69B4 !important;
            font-weight: 600;
        }

        .f-cur {
            font-family: 'Dancing Script', cursive;
        }

        .f-nun {
            font-family: 'Nunito', sans-serif;
        }

        .f-pix {
            font-family: 'Press Start 2P', system-ui;
        }

        .f-qs {
            font-family: 'Quicksand', sans-serif;
        }

        .f-ms {
            font-family: 'Montserrat', sans-serif;
        }

        .f-amiri {
            font-family: 'Amiri', serif;
        }

        .f-lb {
            font-family: 'Libre Baskerville', serif;
        }

        .f-cairo {
            font-family: 'Cairo', sans-serif;
        }

        /* Structural Classes */
        .g-card {
            background-color: rgba(250, 243, 224, 0.6);
            backdrop-filter: blur(var(--blur)) !important;
            border-radius: var(--rad) !important;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .g-pink {
            background-color: rgba(252, 228, 236, 0.4);
            backdrop-filter: blur(var(--blur)) !important;
            border-radius: var(--rad) !important;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 10px 30px rgba(236, 72, 153, 0.1);
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* Vinyl Animation */
        .vinyl-disc {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: #111;
            padding: 5px;
            position: relative;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin: 0 auto;
        }

        .vinyl-disc::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: repeating-radial-gradient(circle, #333 0, #333 1px, transparent 1px, transparent 3px);
            opacity: 0.3;
        }

        .vinyl-art {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #000;
        }

        .vinyl-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 25px;
            height: 25px;
            background: #fff;
            border-radius: 50%;
            border: 4px solid #111;
            z-index: 10;
        }

        .spinning {
            animation: vinylRotate 4s linear infinite;
            transform: translate3d(0, 0, 0);
            will-change: transform;
        }

        @keyframes vinylRotate {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Spotify Widget Styles */
        .spot-style-1 {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .spot-vibrant {
            background: rgba(255, 255, 255, 0.15) !important;
            backdrop-filter: blur(25px) saturate(1.5);
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 35px;
            box-shadow: 0 8px 32px 0 rgba(236, 72, 153, 0.3);
        }

        .spot-minimal {
            background: rgba(0, 0, 0, 0.7) !important;
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            color: white !important;
        }

        .spot-retro {
            background: rgba(255, 255, 255, 0.4) !important;
            backdrop-filter: blur(12px);
            border-radius: 30px;
            border: 2px solid rgba(255, 255, 255, 0.8);
            box-shadow: 10px 10px 20px rgba(0, 0, 0, 0.05);
        }

        /* Pixel Heart Background */
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: -1;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='40' viewBox='0 0 16 16'><path d='M2,6 L2,8 L0,8 L0,12 L2,12 L2,14 L4,14 L4,16 L6,16 L6,18 L10,18 L10,16 L12,16 L12,14 L14,14 L14,12 L16,12 L16,8 L14,8 L14,6 L12,6 L12,4 L10,4 L10,2 L6,2 L6,4 L4,4 L4,6 Z' fill='%23ffb6c1' opacity='0.08'/></svg>");
            background-size: 30px 30px;
            pointer-events: none;
        }

        /* Hand-Coded Pixel Heart Trail */
        .heart-particle {
            position: fixed;
            pointer-events: none;
            top: 0;
            left: 0;
            width: 10px;
            height: 10px;
            font-size: 10px;
            z-index: 99999;
            animation: heartFloat 1.2s forwards linear;
        }

        @keyframes heartFloat {
            0% {
                transform: translateY(0) scale(1);
                opacity: 1;
            }

            100% {
                transform: translateY(-100px) scale(0);
                opacity: 0;
            }
        }

        /* ADVANCED HEART STROBE & VIBRATE */
        @keyframes heartVibrateGlow {

            0%,
            100% {
                transform: scale(1);
                box-shadow: 0 0 10px rgba(236, 72, 153, 0.3);
            }

            50% {
                transform: scale(1.1) rotate(5deg);
                box-shadow: 0 0 40px rgba(236, 72, 153, 0.8);
            }
        }

        .vibrate-pink {
            animation: heartVibrateGlow 0.15s infinite ease-in-out !important;
        }

        @keyframes screenStrobe {
            0% {
                background: rgba(255, 255, 255, 0);
            }

            50% {
                background: rgba(255, 192, 203, 0.4);
            }

            100% {
                background: rgba(255, 255, 255, 0);
            }
        }

        .strobe-active::after {
            content: '';
            position: fixed;
            inset: 0;
            z-index: 99999;
            animation: screenStrobe 0.15s infinite;
            pointer-events: none;
        }

        @keyframes heartScaleIntense {
            0% {
                transform: scale(1);
            }

            100% {
                transform: scale(2.2);
            }
        }

        .intense-scale {
            animation: heartScaleIntense 0.4s infinite alternate ease-in-out !important;
        }

        /* CAPSULE CREATOR GLASS */
        .capsule-modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(20px);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .capsule-content {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 40px;
            padding: 30px;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
            border: 1px solid white;
        }

        /* Peace Treaty Section */
        .mood-emoji {
            font-size: 32px;
            cursor: pointer;
            transition: all 0.2s;
            filter: grayscale(1);
            padding: 10px;
            border-radius: 15px;
        }

        .mood-emoji.active {
            filter: grayscale(0);
            background: rgba(59, 130, 246, 0.1);
            transform: scale(1.2);
        }

        .hug-pulse {
            animation: hugPulse 2s infinite;
        }

        @keyframes hugPulse {
            0% {
                box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4);
            }

            70% {
                box-shadow: 0 0 0 20px rgba(59, 130, 246, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(59, 130, 246, 0);
            }
        }

        /* Love Radar (Leaflet) styling */
        #love-radar-map {
            width: 100%;
            height: 250px;
            border-radius: 35px;
            border: 4px solid white;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            z-index: 10;
        }

        .leaflet-container {
            background: #fdf2f8 !important;
        }

        /* CARTOON OVERHAUL: Hand-drawn look filters */
        .leaflet-layer {
            filter: saturate(1.6) contrast(1.1) brightness(1.05) sepia(0.05);
        }

        .map-marker-y,
        .map-marker-m {
            filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.1));
            border: 3px solid white;
            border-radius: 50% !important;
            box-shadow: 0 0 15px rgba(236, 72, 153, 0.2);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .map-marker-y {
            border-color: #3b82f6;
        }

        .map-marker-m {
            border-color: #ec4899;
        }

        .overlay {
            position: fixed;
            z-index: 1000;
            transition: all 0.4s ease;
            display: none;
        }

        .overlay.active {
            display: flex;
            animation: fadeIn 0.3s;
        }

        .drawer {
            position: fixed;
            top: 0;
            width: 100%;
            height: 100%;
            background: var(--bg);
            transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
            transform: translate3d(0, 0, 0);
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }

        #jn-d {
            z-index: 900;
            transform: translateX(-100%);
            left: 0;
        }

        #sk-d {
            z-index: 1050;
            transform: translateX(100%);
            right: 0;
            border-left: 1px solid #fee2e2;
        }

        .drawer.open-l {
            transform: translateX(0) !important;
        }

        .drawer.open-r {
            transform: translateX(0) !important;
        }

        /* Draggables */
        .f-drag {
            position: fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 500;
            cursor: move;
            touch-action: none;
        }

        .pulse {
            animation: pulseAnim 2s infinite alternate;
        }

        @keyframes pulseAnim {
            0% {
                transform: scale(1);
            }

            100% {
                transform: scale(1.05);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes slideUp {
            from {
                transform: translateY(100%);
            }

            to {
                transform: translateY(0);
            }
        }

        /* Tinder Engine */
        .deck {
            position: relative;
            width: 100%;
            height: 400px;
            display: flex;
            justify-content: center;
            perspective: 1000px;
        }

        .scard {
            position: absolute;
            width: 85%;
            height: 100%;
            background: white;
            border-radius: var(--rad);
            padding: 10px 10px 12px 10px;
            /* Slimmed down Notch */
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            transform-origin: 50% 100%;
            transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.2s ease-out;
            cursor: grab;
            border: 1px solid #f3f4f6;
            will-change: transform;
        }

        .scard img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 32px;
            pointer-events: none;
        }

        .moving {
            transition: none !important;
            cursor: grabbing;
        }

        /* Specific Modifiers */
        .neon-b {
            box-shadow: 0 0 20px rgba(96, 165, 250, 0.6), inset 0 0 10px rgba(96, 165, 250, 0.4);
            border: 2px solid #93c5fd;
            animation: pulseBlueGlow 1.5s infinite alternate;
        }

        @keyframes pulseBlueGlow {
            0% {
                box-shadow: 0 0 15px rgba(96, 165, 250, 0.4), inset 0 0 10px rgba(96, 165, 250, 0.2);
            }

            100% {
                box-shadow: 0 0 30px rgba(96, 165, 250, 0.9), inset 0 0 15px rgba(96, 165, 250, 0.6);
            }
        }

        /* PREMIUM JOURNAL STYLES */
        .journal-container {
            position: relative;
            width: 100%;
            max-width: 380px;
            margin: 0 auto;
            perspective: 1000px;
        }

        .journal-outer {
            background: linear-gradient(135deg, #4a0404 0%, #2d0202 100%);
            border-radius: 20px;
            padding: 15px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), inset 0 2px 4px rgba(255, 255, 255, 0.1);
            position: relative;
            border: 1px solid #1a0101;
        }

        /* Leather texture overlay */
        .journal-outer::before {
            content: "";
            position: absolute;
            inset: 0;
            opacity: 0.15;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            pointer-events: none;
            border-radius: 20px;
        }

        .journal-inner {
            background: #fffbf0;
            border-radius: 4px;
            height: 400px;
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.1);
            display: flex;
        }

        /* Central Fold & Rings */
        .journal-fold {
            display: none;
        }

        .journal-rings {
            display: none;
        }

        .ring {
            display: none;
        }

        /* Lined Paper */
        .paper-lines {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(#e0dcd0 1px, transparent 1px);
            background-size: 100% 28px;
            background-position: 0 10px;
            pointer-events: none;
        }

        /* Mode Tabs */
        .journal-tabs {
            position: absolute;
            left: -35px;
            top: 40px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            z-index: 30;
        }

        .mode-tab {
            width: 35px;
            height: 60px;
            background: rgba(180, 83, 9, 0.85);
            backdrop-filter: blur(8px);
            /* Gold/Leather accent with glassmorphism */
            border-radius: 12px 0 0 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            writing-mode: vertical-lr;
            transform: rotate(180deg);
            padding: 5px 0;
            font-size: 9px;
            font-weight: 900;
            color: rgba(255, 255, 255, 0.7);
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            box-shadow: -2px 4px 6px rgba(0, 0, 0, 0.2);
            border: 1px solid #78350f;
            border-right: none;
        }

        .mode-tab:hover {
            width: 40px;
            color: #fff;
        }

        .mode-tab.active {
            background: rgba(217, 119, 6, 0.95);
            /* Brighter gold */
            width: 48px;
            color: #fff;
            box-shadow: -6px 8px 20px rgba(0, 0, 0, 0.35);
            transform: rotate(180deg) scale(1.08);
            border-right: none;
        }

        .mode-tab:active {
            transform: rotate(180deg) scale(0.95);
        }

        /* Font Sidebar (Type Mode) */
        .font-sidebar {
            position: absolute;
            right: -45px;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.9);
            padding: 10px 5px;
            border-radius: 20px;
            box-shadow: 5px 5px 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 40;
            border: 1px solid #eee;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
            pointer-events: none;
        }

        .font-sidebar.visible {
            opacity: 1;
            pointer-events: auto;
            right: 15px;
        }

        .font-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border: 2px solid #f3f4f6;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
            color: #6b7280;
        }

        .font-btn:hover {
            border-color: #f472b6;
            color: #f472b6;
            transform: scale(1.1);
        }

        .font-btn.active {
            background: #f472b6;
            border-color: #f472b6;
            color: white;
            box-shadow: 0 4px 10px rgba(244, 114, 182, 0.3);
        }

        /* Canvas Overlay for Paper */
        #d-cvs {
            mix-blend-mode: multiply;
            /* Draw over the lines naturally */
        }

        /* Typearea Over Paper */
        #journal-typearea {
            position: absolute;
            inset: 10px 20px;
            background: transparent;
            border: none;
            outline: none;
            resize: none;
            line-height: 28px;
            /* Must match paper-lines bg-size */
            color: #374151;
            z-index: 10;
            padding: 0;
            display: none;
        }

        .type-mode #journal-typearea {
            display: block;
        }

        .type-mode #d-cvs,
        .type-mode .pen-kit {
            opacity: 0.1;
            pointer-events: none;
        }

        .draw-mode #journal-typearea {
            display: none;
        }

        .draw-mode #d-cvs {
            opacity: 1;
            pointer-events: auto;
        }

        .bg-heart {
            position: fixed;
            z-index: -1;
            opacity: 0.15;
            pointer-events: none;
            image-rendering: pixelated;
        }

        #anim-cvs,
        #trail-cvs {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 9999;
        }

        .mission-item {
            animation: mission-fade 0.6s cubic-bezier(0.23, 1, 0.32, 1) both;
        }

        @keyframes mission-fade {
            0% {
                opacity: 0;
                transform: translateY(20px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .c-icon {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 10000;
            font-size: 24px;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

