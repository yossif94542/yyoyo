                            }
                            if (users.marium) {
                                const mHtml = `<div style="width: 44px; height: 44px; border-radius: 50%; background-image: url('${db.m_img || SVG_GOLD}'); background-size: cover; background-position: center; border: 3px solid white; box-shadow: 0 0 20px #ffb6c1;"></div>`;
