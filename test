                            if (users.yossif) {
                                const yHtml = `<div style="width: 44px; height: 44px; border-radius: 50%; background-image: url('${db.y_img || SVG_GOLD}'); background-size: cover; background-position: center; border: 3px solid white; box-shadow: 0 0 20px #ffd700;"></div>`;
                                const yIcon = L.divIcon({ html: yHtml, className: 'map-marker-y', iconSize: [44, 44] });

                                yPos = [users.yossif.lat, users.yossif.lng];
                                if (!yMarker) { yMarker = L.marker(yPos, { icon: yIcon }).addTo(map); }
