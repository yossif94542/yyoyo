                const rect = e.currentTarget.getBoundingClientRect();
                const x = (e.clientX || e.touches[0].clientX) - rect.left;
                const perc = Math.max(0, Math.min(1, x / rect.width));
                if (!isNaN(window.activeAudio.duration)) {
                    window.activeAudio.currentTime = window.activeAudio.duration * perc;
                }
            };

            window.playVoiceMsg = function (id, url) {
                if (window.activeAudioId === id && window.activeAudio) {
                    if (!window.activeAudio.paused) {
                        window.activeAudio.pause();
                        document.getElementById(`v-icon-${id}`).className = 'ri-play-fill text-2xl opacity-80';
                    } else {
                        window.activeAudio.play();
                        document.getElementById(`v-icon-${id}`).className = 'ri-pause-line text-2xl opacity-80';
                    }
                    return;
                }

                if (window.activeAudio) {
                    window.activeAudio.pause();
                    window.activeAudio.currentTime = 0;
                    if (window.activeAudioId) {
                        const oldIcon = document.getElementById(`v-icon-${window.activeAudioId}`);
                        const oldProg = document.getElementById(`v-prog-${window.activeAudioId}`);
                        if (oldIcon) oldIcon.className = 'ri-play-fill text-2xl opacity-80';
                        if (oldProg) oldProg.style.width = '0%';
                    }
                }

                window.activeAudioId = id;
                window.activeAudio = new Audio(url);

                const icon = document.getElementById(`v-icon-${id}`);
                const prog = document.getElementById(`v-prog-${id}`);
                const timeSpan = document.getElementById(`v-time-${id}`);

                icon.className = 'ri-pause-line text-2xl opacity-80';

                window.activeAudio.addEventListener('timeupdate', () => {
                    const perc = (window.activeAudio.currentTime / window.activeAudio.duration) * 100 || 0;
                    if (prog) prog.style.width = `${perc}%`;
                    if (timeSpan) {
                        const sec = Math.floor(window.activeAudio.currentTime);
                        timeSpan.innerText = `0:${sec.toString().padStart(2, '0')}`;
                    }
                });

                window.activeAudio.addEventListener('ended', () => {
                    if (icon) icon.className = 'ri-play-fill text-2xl opacity-80';
                    if (prog) prog.style.width = '0%';
                    if (timeSpan) timeSpan.innerText = '0:00';
                    window.activeAudio = null;
                    window.activeAudioId = null;
                });

                window.activeAudio.play();
            };

