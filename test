                const item = db.ownedItems[id];

                if (item.type === 'theme' && !item.active) {
                    Object.keys(db.ownedItems).forEach(key => {
                        if (db.ownedItems[key].type === 'theme') db.ownedItems[key].active = false;
                    });
                }

                item.active = !item.active;
                svDB();
                renderMyItems();
            };

            // 4. UI Rendering
            function renderShopProducts() {
                const list = document.getElementById('shop-product-list');
                if (!db.products) return list.innerHTML = "<p class='text-center py-10 opacity-30'>Loading products...</p>";

                const filtered = db.products.filter(p => !window.currentShopCat || window.currentShopCat === 'All' || p.cat === window.currentShopCat);

                list.innerHTML = filtered.map(p => {
                    const discount = p.discount || 0;
                    const finalPrice = Math.floor(p.cost * (1 - discount / 100));

                    const isOwned = p.type === 'font'
                        ? (db.purchasedFonts && db.purchasedFonts[currentUser] && db.purchasedFonts[currentUser][p.id])
                        : (db.ownedItems && db.ownedItems[p.id]);

                    return `
                        <div class="p-card ${isOwned ? 'opacity-40' : ''}">
                            <div class="p-icon">${p.icon}</div>
                            <div class="p-info">
                                <span class="p-tag">${p.category || p.cat || 'Special'}</span>
                                <h4 class="p-title">${p.name}</h4>
                                <div class="p-price-wrap">
                                    <span class="p-price">${finalPrice || 'Free'} ${finalPrice ? '🪙' : ''}</span>
                                    ${discount > 0 ? `<span class="p-old-price">${p.cost}</span>` : ''}
                                </div>
                            </div>
                            <div class="p-btn-row">
                                ${isOwned ? '<span class="text-[10px] font-black uppercase text-[#FF7096]">Owned</span>' : `
                                    <button onclick="buyProduct('${p.id}', false)" class="p-buy">Buy</button>
                                    <button onclick="buyProduct('${p.id}', true)" class="p-gift">🎁</button>
                                `}
                            </div>
                        </div>
                    `;
                }).join('');
            }

            function renderMyItems() {
                const list = document.getElementById('shop-product-list');
                if (!db.ownedItems || Object.keys(db.ownedItems).length === 0) {
                    return list.innerHTML = "<p class='text-center py-20 font-bold text-white/20'>No items in your backpack yet. 🎒</p>";
                }

                list.innerHTML = Object.keys(db.ownedItems).map(id => {
                    const item = db.ownedItems[id];
                    return `
                        <div class="p-card">
                            <div class="p-icon">${id.startsWith('p') ? '📦' : '✨'}</div>
                            <div class="p-info">
                                <span class="p-tag">${item.type || 'Item'}</span>
                                <h4 class="p-title">${item.title}</h4>
                                <p class="text-[9px] text-[#6E6B74]">Unlocked on ${new Date(item.at).toLocaleDateString()}</p>
                            </div>
                            <div class="m-switch ${item.active ? 'on' : ''}" onclick="toggleItem('${id}')"></div>
                        </div>
                    `;
                }).join('');
            }

            function renderRechargePackages() {
                const list = document.getElementById('shop-product-list');
                const packs = [
                    { coins: 100, egp: 20 },
                    { coins: 250, egp: 50 },
                    { coins: 500, egp: 100 },
                    { coins: 1000, egp: 200 }
                ];

                const renderHTML = (hasPending) => {
                    const pendingBanner = hasPending ? `
                    <div class="bg-yellow-500/20 border border-yellow-500/50 p-4 rounded-xl mb-6 w-full max-w-sm mx-auto shadow-[0_0_15px_rgba(234,179,8,0.15)] flex flex-col items-center justify-center backdrop-blur-md">
                        <div class="flex items-center justify-center gap-2 mb-1 w-full text-center">
                            <i class="ri-loader-4-line animate-spin text-yellow-400 text-xl font-black"></i>
                            <span class="text-yellow-400 font-black text-[13px] uppercase tracking-widest f-pop">Pending Approval</span>
                        </div>
                        <p class="text-[10px] text-yellow-500/80 font-bold uppercase tracking-widest text-center mt-1 w-full f-pop">Your recent recharge request is awaiting review by Master HQ</p>
                    </div>
                    ` : '';

                    const cards = packs.map(px => `
                    <div onclick="confirmRecharge(${px.coins}, ${px.egp})" class="p-card overflow-hidden relative flex-col justify-center items-center py-6 w-full max-w-sm mx-auto cursor-pointer hover:border-[#FF7096]/50 group">
                        <div class="absolute -right-6 -top-6 opacity-[0.03] text-[120px] transition-transform group-hover:scale-110">🪙</div>
                        <div class="p-icon text-5xl drop-shadow-lg relative z-10 flex justify-center border-0 shadow-none !bg-transparent mb-2 transition-transform group-hover:scale-110">🪙</div>
                        <div class="p-info text-center w-full relative z-10 flex flex-col items-center">
                            <div class="flex items-center justify-center gap-3">
                                <h4 class="p-title text-3xl font-black text-white mb-0 tracking-tight drop-shadow-md group-hover:text-[#FF7096] transition-colors">🪙 ${px.coins} <span class="text-lg opacity-80">Coins</span></h4>
                                <div class="bg-[#FF7096]/20 border border-[#FF7096]/50 px-3 py-1 rounded-xl backdrop-blur-sm shadow-inner group-hover:bg-[#FF7096] group-hover:text-white transition-colors">
                                    <span class="text-[#FF7096] group-hover:text-white font-black text-sm tracking-wider transition-colors">${px.egp} EGP</span>
                                </div>
                            </div>
                        </div>
                        <div class="p-btn-row w-full relative z-10 pointer-events-none mt-5">
                            <button class="w-full bg-white/10 border border-white/20 group-hover:bg-[#FF7096] group-hover:border-[#FF7096] text-white py-3 px-4 rounded-[14px] shadow-[0_4px_15px_rgba(0,0,0,0.1)] flex flex-col items-center justify-center gap-1 backdrop-blur-md transition-all">
                                <span class="font-black text-sm">Buy Now</span>
                                <span class="text-[9px] font-bold text-white/70 tracking-widest">شراء الآن</span>
                            </button>
                        </div>
                    </div>
                    `).join('');

                    return pendingBanner + cards;
                };

                list.innerHTML = renderHTML(false);

                if (window.firebaseData && currentUser && currentUser !== 'guest') {
                    window.firebaseData.ref('paymentRequests').orderByChild('user').equalTo(currentUser).once('value', snap => {
                        let pending = false;
                        snap.forEach(child => { if (child.val().status === 'pending') pending = true; });
                        if (pending) list.innerHTML = renderHTML(true);
                    });
                }
            }

            let pendingRecharge = null;
            window.confirmRecharge = function (coins, egp) {
                pendingRecharge = { coins, egp };
                document.getElementById('rech-egp-val').innerText = egp;
                const coinsVal = document.getElementById('rech-coins-val');
                if (coinsVal) coinsVal.innerText = coins;
                document.getElementById('recharge-modal').style.display = 'flex';
                const successScreen = document.getElementById('order-success-screen');
                if (successScreen) {
                    successScreen.classList.add('hidden', 'opacity-0', 'translate-y-4');
                    successScreen.classList.remove('flex');
                }
            };

            window.handlePurchase = async function () {
                if (!pendingRecharge || currentUser === 'guest') return;

                const receiptInput = document.getElementById('rech-receipt-img');
                const errText = document.getElementById('rech-receipt-err');

                if (!receiptInput.files || receiptInput.files.length === 0) {
                    if (errText) errText.classList.remove('hidden');
                    return;
                }
                if (errText) errText.classList.add('hidden');

                const file = receiptInput.files[0];
                triggerGlobalLoading(true);

                try {
                    const blob = await compressToBlob(file, 1000, 0.7);
                    const path = `receipts/${currentUser}/order_${Date.now()}.jpg`;
                    const url = await uploadToStorage(blob, path);

                    const radios = document.getElementsByName('pay_method');
                    let payMethod = 'Unknown';
                    if (radios.length > 0 && radios[0].checked) payMethod = 'Vodafone Cash';
                    else if (radios.length > 1 && radios[1].checked) payMethod = 'Fawry';

                    const reqRef = window.firebaseData.ref('rechargeRequests').push();
                    const genId = Math.floor(Math.random() * 90000000) + 10000000;

                    await reqRef.set({
                        id: reqRef.key,
                        displayId: genId,
                        user: currentUser,
                        coinsAmount: pendingRecharge.coins,
                        amountEGP: pendingRecharge.egp,
                        method: payMethod,
                        screenshot: url,
                        timestamp: firebase.database.ServerValue.TIMESTAMP,
                        status: 'pending'
                    });

                    triggerGlobalLoading(false);
                    const successScreen = document.getElementById('order-success-screen');
                    if (successScreen) {
                        document.getElementById('gen-order-id').innerText = genId;
                        document.getElementById('order-acc-name').innerText = currentUser;
                        document.getElementById('order-egp-val').innerText = pendingRecharge.egp;
                        const oc = document.getElementById('order-coins-val');
                        if (oc) oc.innerText = pendingRecharge.coins;
                        successScreen.classList.remove('hidden');
                        successScreen.classList.add('flex');
                        setTimeout(() => {
                            successScreen.classList.remove('opacity-0', 'translate-y-4');
                        }, 50);
                    } else {
                        document.getElementById('recharge-modal').style.display = 'none';
                    }
                    receiptInput.value = '';
                } catch (err) {
                    console.error('Submission Error:', err);
                    triggerGlobalLoading(false);
                    alert('Order Sync Failed. Please check connection.');
                }
            };

            function renderProductEditor() {
                const list = document.getElementById('product-editor-list');
                const initialProducts = [
                    { id: 'extra_photo_1', name: '1 Extra Photo Slot', cost: 100, type: 'upgrade', cat: 'Upgrades', icon: '🖼️' },
                    { id: 'extra_photo_10', name: 'Mega Photo Pack (+10)', cost: 1000, type: 'upgrade', cat: 'Upgrades', icon: '📸' },
                    { id: 'music_switcher', name: 'Music Switcher', cost: 100, type: 'consumable', cat: 'Upgrades', icon: '🎵' },
                    { id: 'story_editor', name: 'Story Editor Access', cost: 200, type: 'unlock', cat: 'Upgrades', icon: '✍️' },
                    { id: 'p1', name: 'Midnight Rose', cost: 500, type: 'theme', cat: 'Themes', category: 'Themes', icon: '🌹' },
                    { id: 'p2', name: 'Neon Cyber', cost: 700, type: 'theme', cat: 'Themes', category: 'Themes', icon: '🌃' },
                    { id: 'p3', name: 'Vintage Polaroid', cost: 400, type: 'theme', cat: 'Themes', category: 'Themes', icon: '📸' },
                    { id: 'p4', name: 'Floating Hearts', cost: 300, type: 'effect', cat: 'Effects', category: 'Effects', icon: '💖' },
                    { id: 'p5', name: 'Starry Sky', cost: 450, type: 'effect', cat: 'Effects', category: 'Effects', icon: '⭐' },
                    { id: 'p6', name: 'Snowfall', cost: 250, type: 'effect', cat: 'Effects', category: 'Effects', icon: '❄️' }
                ];
                if (!db.products || db.products.length < 5) db.products = initialProducts;

                list.innerHTML = db.products.map(p => `
                    <div class="bg-[#1C1821] p-4 rounded-3xl border border-white/5 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="text-xl">${p.icon}</span>
                            <div>
                                <h5 class="text-xs font-black text-white">${p.name}</h5>
                                <p class="text-[9px] text-[#6E6B74] uppercase font-bold">${p.cost} 🪙 • ${p.cat}</p>
                            </div>
                        </div>
                        <div class="flex gap-2">
                             <i class="ri-delete-bin-line text-red-500/50 cursor-pointer" onclick="deleteProduct('${p.id}')"></i>
                        </div>
                    </div>
                `).join('');

                updateInventoryList();
            }

            function updateInventoryList() {
                const inv = document.getElementById('m-inventory-list');
                if (!inv) return;

                const allItems = db.products || [];
                inv.innerHTML = allItems.map(p => {
                    const isOwned = db.ownedItems && db.ownedItems[p.id];
                    return `
                        <div class="bg-[#1C1821] p-3 rounded-2xl border border-white/5 flex flex-col gap-2 items-center text-center">
                            <span class="text-xl">${p.icon}</span>
                            <span class="text-[9px] font-black text-white uppercase truncate w-full">${p.name}</span>
                            <button onclick="grantOverride('${p.id}', ${isOwned ? 'true' : 'false'})" 
                                    class="w-full text-[8px] font-black p-2 rounded-xl ${isOwned ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400'}">
                                ${isOwned ? 'REVOKE' : 'GRANT'}
                            </button>
                        </div>
                    `;
                }).join('');
            }

            window.grantOverride = function (id, revoke) {
                const p = db.products.find(x => x.id === id);
                if (!p) return;

                if (!db.ownedItems) db.ownedItems = {};
                if (revoke) {
                    delete db.ownedItems[id];
                    logOrder('Admin', `Revoked ${p.name}`);
                } else {
                    db.ownedItems[id] = { at: Date.now(), title: p.name, type: p.type, active: true };
                    logOrder('Admin', `Granted ${p.name}`);
                }
                svDB();
                renderProductEditor();
                renderMyItems(); // instantly updates Marium's perspective if open
            };

            function logOrder(user, action) {
                if (!db.orderLogs) db.orderLogs = [];
                db.orderLogs.unshift({ at: new Date().toLocaleTimeString(), user, action });
                if (db.orderLogs.length > 10) db.orderLogs.pop();
                renderOrderLog();
            }

            function renderOrderLog() {
                const list = document.getElementById('order-log-list');
                if (!list || !db.orderLogs) return;
                list.innerHTML = db.orderLogs.map(l => `
                    <div class="order-log-item">
                        <span>[${l.at}] <b>${l.user}</b></span>
                        <span class="text-[#FF7096]">${l.action}</span>
                    </div>
                `).join('');
            }

            function loadMasterOrders() {
                if (currentUser === 'master' || currentUser === 'master2026') {
                    window.firebaseData.ref('rechargeRequests').on('value', snap => {
                        const listEl = document.getElementById('orders-container');
                        if (!listEl) return;

                        listEl.innerHTML = '';

                        const reqs = snap.val();
                        if (!reqs) {
                            listEl.innerHTML = '<p class="text-center text-gray-500/50 py-10 font-black text-xl tracking-widest uppercase">No pending orders yet ☕</p>';
                            return;
                        }

                        const pendingList = Object.values(reqs).filter(r => r.status === 'pending');
                        if (pendingList.length === 0) {
                            listEl.innerHTML = '<p class="text-center text-gray-500/50 py-10 font-black text-xl tracking-widest uppercase">No pending orders yet ☕</p>';
                            return;
                        }

                        listEl.innerHTML = pendingList.map(r => `
                            <div class="bg-[#1C1821] p-5 rounded-2xl border border-white/5 flex flex-col gap-3 relative overflow-hidden shadow-lg">
                                <div class="absolute -right-4 -bottom-4 opacity-5 text-[100px] pointer-events-none">🪙</div>
                                <div class="flex justify-between items-start z-10 w-full text-left">
                                    <div class="w-full">
                                        <h4 class="text-white font-black text-2xl mb-1">${r.coinsAmount} Coins 🪙</h4>
                                        <div class="flex items-center gap-2">
                                            <span class="text-green-400 text-[13px] font-black bg-green-400/10 border border-green-400/20 px-3 py-1 rounded-lg">${r.amountEGP} EGP</span>
                                            <span class="text-gray-500 text-[10px] font-bold uppercase tracking-widest">${r.method || 'Cash'}</span>
                                        </div>
                                        <div class="mt-4 bg-black/40 p-3 rounded-xl flex items-center justify-between">
                                            <div>
                                                <p class="text-xs text-gray-400 font-bold">User: <span class="text-pink-400 font-black uppercase tracking-widest text-[14px] ml-1">${r.user}</span></p>
                                                <p class="text-[10px] text-gray-600 mt-1 uppercase tracking-widest">${new Date(r.timestamp).toLocaleString()}</p>
                                            </div>
                                            ${r.screenshot ? `<a href="${r.screenshot}" target="_blank" class="bg-indigo-600/20 hover:bg-indigo-600/40 border border-indigo-500/50 p-2 rounded-lg text-indigo-400 flex flex-col items-center justify-center transition-colors shadow-inner" style="min-width:60px" title="View Proof"><i class="ri-image-2-fill text-xl mb-1"></i><span class="text-[8px] font-black tracking-widest uppercase">Proof</span></a>` : ''}
                                        </div>
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-3 mt-3 z-10 w-full">
                                    <button onclick="approveOrder('${r.id}', ${r.coinsAmount}, ${r.amountEGP})" class="bg-gradient-to-br from-green-500 to-emerald-700 text-white shadow-[0_0_20px_rgba(34,197,94,0.3)] py-4 rounded-xl font-black uppercase tracking-widest text-[11px] hover:scale-105 transition-transform border border-green-400/50 flex flex-col items-center justify-center"><span class="text-lg mb-1">✅</span> Approve</button>
                                    <button onclick="rejectOrder('${r.id}')" class="bg-[#111] text-red-500 border border-red-500/30 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] hover:bg-red-500/10 transition-colors flex flex-col items-center justify-center"><span class="text-lg mb-1">❌</span> Reject</button>
                                </div>
                            </div>
                        `).join('');
                    }, (err) => {
                        console.error('Firebase DB Connection Error:', err);
                        alert('Firebase Connection Failed');
                    });
                }
            }

            window.approveOrder = function (id, coinsAmt, egpAmt) {
                // Play Success Audio
                try {
                    const sfx = new Audio('https://actions.google.com/sounds/v1/cartoon/magic_chime_bell.ogg');
                    sfx.volume = 0.5;
                    sfx.play().catch(e => console.log('Audio blocked', e));
                } catch (e) { }

                // Visual Coin Popping Effect
                for (let i = 0; i < 30; i++) {
                    setTimeout(() => {
                        const c = document.createElement('div');
                        c.className = 'coin-pop';
                        c.style.left = (Math.random() * 90 + 5) + 'vw';
                        document.body.appendChild(c);
                        setTimeout(() => c.remove(), 1200);
                    }, Math.random() * 400);
                }

                if (!db.coins_marium) db.coins_marium = 0;
                db.coins_marium += coinsAmt;

                if (!db.totalSpentEGP) db.totalSpentEGP = 0;
                db.totalSpentEGP += egpAmt;

                logOrder('Yossif (HQ)', `Approved ${coinsAmt}🪙 for ${egpAmt} EGP`);
                svDB();

                window.firebaseData.ref(`rechargeRequests/${id}`).update({ status: 'approved' });

                const mariumCoins = document.getElementById('marium-coins');
                if (mariumCoins) mariumCoins.innerText = db.coins_marium + " 🪙";
                const mariumSpent = document.getElementById('marium-spent');
                if (mariumSpent) mariumSpent.innerText = "Total Spent: " + db.totalSpentEGP + " EGP";

                if (navigator.vibrate) navigator.vibrate([100, 50, 100, 50, 200]);
            };

            window.rejectOrder = function (id) {
                if (confirm('Are you sure you want to REJECT and DELETE this coin request?')) {
                    window.firebaseData.ref(`rechargeRequests/${id}`).update({ status: 'rejected' });
                    logOrder('Yossif (HQ)', 'Rejected a recharge request');
                }
            };

            window.saveStore = function () {
                svDB();
                alert("Economy Core Synced! 💎");
            };

            window.triggerSurprise = function (type) {
                if (firebase.apps.length > 0) {
                    firebase.database().ref('surprise_trigger').set({
                        type: type,
                        at: Date.now(),
                        active: true
                    });
                    alert(`Surprise ${type} deployed! 🚀`);
                }
            };

            window.updateAdminCreds = function (target) {
                const u = document.getElementById(`admin-${target}-user`).value.trim();
                const p = document.getElementById(`admin-${target}-pass`).value.trim();
                if (!u || !p) return alert("Please fill in both fields.");
                if (confirm(`Overwrite ${target} credentials globally?`)) {
                    window.firebaseData.ref(`adminConfig/credentials/${target}`).set({ u: u, p: p }).then(() => {
                        alert(`${target.toUpperCase()} credentials securely updated.`);
                    }).catch(e => alert("Update failed. Check connection."));
                }
            };

            // Final Deployment Security Embed
            document.addEventListener('contextmenu', e => e.preventDefault());

            console.log("💎 Zokra Vault 2026: End of Script reached successfully.");
        </script>
</body>

