            window.buyProduct = function (id, isGift) {
                const p = db.products.find(x => x.id === id);
                if (!p) return;

                const finalCost = Math.floor(p.cost * (1 - (p.discount || 0) / 100));

                // Fetch dynamic active coin balance based on current user
                const coinsKey = currentUser === 'yossif' ? 'coins_yossif' : 'coins_marium';
                if ((db[coinsKey] || 0) < finalCost) return alert(`Not enough coins! 🪙 You need ${finalCost}`);

                if (!db.ownedItems) db.ownedItems = {};

                // Intercept Font Economy System
                if (p.type === 'font') {
                    if (!db.purchasedFonts) db.purchasedFonts = { marium: {}, yossif: {} };
                    if (!db.purchasedFonts[currentUser]) db.purchasedFonts[currentUser] = {};
                    if (db.purchasedFonts[currentUser][id]) return alert("Font already purchased! 💖");

                    db[coinsKey] -= finalCost;
                    db.purchasedFonts[currentUser][id] = true;
                    svDB();
                    updateSoulUI(); // Instantly unblur
                    if (window.renderShopProducts) renderShopProducts(); // Refresh buttons
                    return;
                }

                // Upgrade/Consumable logic: persistent items vs stackable effects
                if (p.type === 'unlock' && db.ownedItems[id]) return alert("Item already owned! 🎒");

                db[coinsKey] -= finalCost;

                // --- EFFECT PAYLOADS ---
                if (id === 'extra_photo_1') db.galleryLimit = (db.galleryLimit || 5) + 1;
                if (id === 'extra_photo_10') db.galleryLimit = (db.galleryLimit || 5) + 10;
                if (id === 'music_switcher') db.musicSwitches = (db.musicSwitches || 0) + 1;
                if (id === 'story_editor') db.storyUnlocked = true;

                db.ownedItems[id] = { at: Date.now(), title: p.name, type: p.type, active: true };

                // Theme override logic (1 at a time)
                if (p.type === 'theme') {
                    Object.keys(db.ownedItems).forEach(key => {
                        if (db.ownedItems[key].type === 'theme' && key !== id) {
                            db.ownedItems[key].active = false;
                        }
                    });
                }

                document.getElementById('u-shop-coins').innerText = db.coins_marium;
                logOrder(currentUser, `Bought ${p.name} (-${finalCost} 🪙)`);
                svDB();
                renderShopProducts();
                if (navigator.vibrate) navigator.vibrate([100, 50, 100]);
                alert(isGift ? `Gift sent to Marium! 🎁` : `Purchase success! ${p.icon}`);
            };

