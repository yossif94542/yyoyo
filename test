            // COMPRESSION & BASE64 BYPASS UTILS (Client-Side)
            function compressToBase64(file, maxW = 800, qual = 0.6) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(file);
                    reader.onload = (e) => {
                        const img = new Image();
                        img.src = e.target.result;
                        img.onload = () => {
                            const canvas = document.createElement('canvas');
                            let w = img.width, h = img.height;
                            if (w > maxW) { h = (maxW / w) * h; w = maxW; }
                            canvas.width = w; canvas.height = h;
                            const ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, w, h);
                            const base64 = canvas.toDataURL('image/jpeg', qual);
                            if (!base64) return reject("Compression failed");
                            resolve(base64);
                        };
                        img.onerror = () => reject("Image load error");
                    };
                    reader.onerror = () => reject("File read error");
                });
            }

            const CLOUD_NAME = '';
            const UPLOAD_PRESET = 'zekra_unsigned';

            // CLOUDINARY UPLOADER 🌤️
            async function uploadToStorage(file, path, resourceType = 'auto') {
                const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/${resourceType}/upload`;
                const formData = new FormData();

                formData.append("file", file);
                formData.append("upload_preset", UPLOAD_PRESET);

                try {
                    const response = await fetch(url, {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) {
                        const errText = await response.text();
                        console.error("Cloudinary upload failed", errText);
                        throw new Error(`Upload failed: ${response.status}`);
                    }

                    const data = await response.json();
                    return data.secure_url;
                } catch (err) {
                    console.error("🔥 CLOUD UPLOAD BLOCKED:", err);
                    alert("Sync Failed: Check your Cloud Name or internet connection.");
                    throw err;
                }
            }

            async function compressToBlob(file, maxW = 800, qual = 0.7) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(file);
                    reader.onload = (e) => {
                        const img = new Image();
                        img.src = e.target.result;
                        img.onload = () => {
                            const canvas = document.createElement('canvas');
                            let w = img.width, h = img.height;
                            if (w > maxW) { h = (maxW / w) * h; w = maxW; }
                            canvas.width = w; canvas.height = h;
                            const ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, w, h);
                            canvas.toBlob((blob) => {
                                if (blob) resolve(blob);
                                else reject("Blob creation failed");
                            }, 'image/jpeg', qual);
                        };
                    };
                });
            }

